    "from abc import ABC, abstractmethod\n",
    "import random\n",
    "class FoodItem(ABC):\n",
    "    def __init__(self, price):\n",
    "        self.__price = price\n",
    "        self.qty = 1\n",
    "    def get_price(self):\n",
    "        return self.__price\n",
    "    def buy(self):\n",
    "        return self.qty > 0 and not self.qty - 1 < 0\n",
    "    @abstractmethod\n",
    "    def name(self): pass\n",
    "class Pizza(FoodItem):\n",
    "    def name(self): return \"Pizza\"\n",
    "class Burger(FoodItem):\n",
    "    def name(self): return \"Burger\"\n",
    "class Drink(FoodItem):\n",
    "    def name(self): return \"Drink\"\n",
    "name = input(\"Name: \")\n",
    "print(\"1.Pizza 2.Burger 3.Drink\")\n",
    "c = int(input(\"Choice: \"))\n",
    "f = Pizza(1200) if c==1 else Burger(800) if c==2 else Drink(300)\n",
    "if f.buy():\n",
    "    total = f.get_price()\n",
    "    if total > 2000:\n",
    "        total *= 0.9\n",
    "    total += total * 0.15\n",
    "    pay = input(\"Cash/Card/Wallet: \")\n",
    "    oid = \"O\" + str(random.randint(1000,9999))\n",
    "    print(\"\\nID:\", oid)\n",
    "    print(\"Name:\", name)\n",
    "    print(\"Item:\", f.name())\n",
    "    print(\"Pay:\", pay)\n",
    "    print(\"Total:\", round(total,2))\n",
    "    open(\"orders.txt\",\"a\").write(f\"{oid} {name} {total}\\n\")\n",
    "\n",
    "else:\n",
    "    print(\"Unavailable\")"
   ]
