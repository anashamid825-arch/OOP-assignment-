    "from abc import ABC, abstractmethod\n",
    "import random\n",
    "class Product(ABC):\n",
    "    def __init__(self, price):\n",
    "        self.__price = price\n",
    "        self.stock = 2\n",
    "    def get_price(self):\n",
    "        return self.__price\n",
    "    def buy(self):\n",
    "        if self.stock > 0:\n",
    "            self.stock -= 1\n",
    "            return True\n",
    "        return False\n",
    "    @abstractmethod\n",
    "    def type(self):\n",
    "        pass\n",
    "class AC(Product):\n",
    "    def type(self):\n",
    "        return \"AC\"\n",
    "class Refrigerator(Product):\n",
    "    def type(self):\n",
    "        return \"Refrigerator\"\n",
    "class WashingMachine(Product):\n",
    "    def type(self):\n",
    "        return \"Washing Machine\"\n",
    "name = input(\"Name: \")\n",
